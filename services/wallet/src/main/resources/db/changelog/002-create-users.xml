<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd">

    <changeSet id="002-create-users" author="digitaltwinapp-api">
        <createTable schemaName="digitaltwinapp" tableName="users">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>ALTER TABLE digitaltwinapp.users
             ADD CONSTRAINT users_status_check CHECK (status IN ('active', 'suspended'))</sql>

        <rollback>
            <dropTable schemaName="digitaltwinapp" tableName="users"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
